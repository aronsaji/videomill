# ============================================================
# VideoMill — Miljøvariabler
# ============================================================
# BRUKSVEILEDNING:
#   1. Kopier denne filen: cp .env.example .env.local
#   2. Fyll inn verdiene for ditt miljø
#   3. .env.local er gitignored — den skal ALDRI committes
#
# VITE_-prefix: Disse variablene er tilgjengelige i klientkoden (nettleseren).
#   → Legg KUN inn offentlige/ikke-sensitive verdier her.
#   → anon-nøkkelen er designet for å være offentlig (beskyttet av RLS).
#
# UTEN VITE_-prefix: Brukes KUN i Supabase Edge Functions (Deno.env.get)
#   → service_role-nøkkelen, n8n-hemmeligheter, RunPod API-nøkler
#   → Konfigureres i Supabase Dashboard → Edge Functions → Secrets
#   → Konfigureres i Vercel Dashboard → Settings → Environment Variables
# ============================================================


# ────────────────────────────────────────────────────────────
# SUPABASE — Frontend (klientkode, VITE_-prefix påkrevd)
# Finn verdiene i: Supabase Dashboard → Project Settings → API
# ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<din-prosjekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...


# ────────────────────────────────────────────────────────────
# SUPABASE — Backend / Edge Functions (ALDRI VITE_-prefix)
# Sett disse i Supabase Dashboard → Edge Functions → Secrets
# OG i Vercel Dashboard → Settings → Environment Variables (Server)
# ────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=eyJ...    # Full admin-tilgang — kun serverside
# SUPABASE_URL=https://<din-prosjekt-ref>.supabase.co


# ────────────────────────────────────────────────────────────
# GOOGLE OAUTH — Client ID (klientkode, VITE_-prefix OK)
# Client ID er offentlig (ikke en hemmelighet), men hør hjemme i .env
# Finn i: Google Cloud Console → APIs & Services → Credentials
# Client Secret skal KUN brukes i n8n/backend — ALDRI i frontend
# ────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=<ditt-client-id>.apps.googleusercontent.com


# ────────────────────────────────────────────────────────────
# n8n — Webhook-konfigurasjon (serverside hemmeligheter)
# Sett i Supabase Edge Function Secrets + Vercel Server-vars
# ────────────────────────────────────────────────────────────
# N8N_TRENDS_WEBHOOK_URL=https://<din-n8n-instans>/webhook/<path>
# N8N_AUTH_WEBHOOK_URL=https://<din-n8n-instans>/webhook/youtube-auth
# N8N_HEADER_AUTH_VALUE=<tilfeldig-generert-hemmelighet-min-32-tegn>
#
# Generer en sterk hemmelighet (Linux/Mac):
#   openssl rand -hex 32
# Windows (PowerShell):
#   [System.Web.Security.Membership]::GeneratePassword(48, 8)


# ────────────────────────────────────────────────────────────
# RUNPOD — API-konfigurasjon (serverside hemmeligheter)
# Sett KUN i Supabase Edge Function Secrets / Vercel Server-vars
# RunPod pod-ID skal ikke eksponeres i klientkoden
# ────────────────────────────────────────────────────────────
# RUNPOD_API_KEY=<din-runpod-api-nøkkel>
# RUNPOD_ENDPOINT_ID=<din-pod-id>
# RUNPOD_BASE_URL=https://<pod-id>-<port>.proxy.runpod.net


# ────────────────────────────────────────────────────────────
# VERCEL — Deployment-konfigurasjon
# Sett i Vercel Dashboard → Settings → Environment Variables
# ────────────────────────────────────────────────────────────
# VERCEL_URL=<din-app>.vercel.app           # Settes automatisk av Vercel
# ALLOWED_ORIGIN=https://<din-app>.vercel.app  # Brukes av Edge Functions til CORS
