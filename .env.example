# ============================================================
# VideoMill — Miljøvariabler (Auto-Production v5.0)
# ============================================================
# BRUKSVEILEDNING:
#   1. Kopier denne filen: cp .env.example .env.local
#   2. Fyll inn verdiene for ditt miljø
#   3. .env.local er gitignored — den skal ALDRI committes
#
# VITE_-prefix: Disse variabler er tilgjengelige i klientkoden (nettleseren).
# UTEN VITE_-prefix: Brukes KUN i Supabase Edge Functions / n8n (serverside)
# ============================================================


# ────────────────────────────────────────────────────────────
# SUPABASE
# ────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<din-prosjekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Server-side kun
# SUPABASE_URL=https://<din-prosjekt-ref>.supabase.co


# ────────────────────────────────────────────────────────────
# CLAUDE 4 SONNET — AI Manus-generering
# ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...             # Fra anthropic.com
# ANTHROPIC_WEBHOOK_URL=<din-edge-fn>    # Supabase Edge Function


# ────────────────────────────────────────────────────────────
# ELEVENLABS — TTS Stemme
# ────────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=sk_...             # Fra elevenlabs.io


# ────────────────────────────────────────────────────────────
# PEXELS / PIXABAY — Stock Video
# ────────────────────────────────────────────────────────────
# PEXELS_API_KEY=...                  # Fra pexels.com/api
# PIXABAY_API_KEY=...                # Fra pixabay.com/api


# ────────────────────────────────────────────────────────────
# n8n — Automasjon
# ────────────────────────────────────────────────────────────
# N8N_HEADER_AUTH_VALUE=<hex-32>        # Generer med: openssl rand -hex 32
# N8N_WEBHOOK_URL=https://<din-n8n>/webhook/viranode-generate


# ────────────────────────────────────────────────────────────
# AUTO-PUBLISERING — TikTok / YouTube
# ────────────────────────────────────────────────────────────
# TIKTOK_UPLOAD_WEBHOOK=https://<din-n8n>/webhook/tiktok-upload
# YOUTUBE_UPLOAD_WEBHOOK=https://<din-n8n>/webhook/youtube-upload
# YOUTUBE_CLIENT_ID=...              # Google Cloud Console
# YOUTUBE_CLIENT_SECRET=...           # Google Cloud Console


# ────────────────────────────────────────────────────────────
# PWA / VERCEL
# ────────────────────────────────────────────────────────────
# VERCEL_URL=<din-app>.vercel.app
# ALLOWED_ORIGIN=https://<din-app>.vercel.app
